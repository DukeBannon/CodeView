<Window x:Class="CodeView.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:CodeView.Models"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="CodeView Prototype"
        MinHeight="760"
        MinWidth="1180"
        Height="900"
        Width="1500"
        Background="#E9E5DC"
        FontFamily="Segoe UI"
        FontSize="14">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,18,6" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#242B33" Padding="22,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="CodeView"
                               Foreground="#FFFDF7"
                               FontSize="30"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Traditional Source Listing Generator"
                               Margin="0,2,0,10"
                               Foreground="#D9D2C5"
                               FontSize="16" />
                    <TextBlock Text="{Binding SelectedRepositoryDisplay}"
                               Foreground="#F1EEE7"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="138"
                        VerticalAlignment="Center"
                        Command="{Binding OpenRepoCommand}"
                        Content="Open Repo..." />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#B8B1A3"
                    BorderThickness="1"
                    Background="#F8F5EE"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Button Command="{Binding ScanRepoCommand}" Content="Scan Repo" />
                        <Button Command="{Binding GeneratePreviewCommand}" Content="Generate Preview" />
                        <Button Click="OnPrintPreviewClick" Content="Print Preview" />
                        <Button Click="OnExportPdfClick" Content="Export PDF" />
                        <Button Command="{Binding ExportHtmlCommand}" Content="Export HTML" />
                        <Button Command="{Binding ExportTextCommand}" Content="Export Text" />
                        <TextBlock Text="File Inventory"
                                   Margin="0,10,0,8"
                                   FontWeight="SemiBold"
                                   Foreground="#242B33" />
                    </StackPanel>

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Files}"
                              BorderBrush="#CFC7B8"
                              Background="#FFFDF7">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Relative Path" Width="245">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:SourceFileInfo}">
                                            <TextBlock Text="{Binding RelativePath}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding RelativePath}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Lines"
                                                Width="72"
                                                DisplayMemberBinding="{Binding LineCount}" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border Grid.Row="2"
                            Margin="0,12,0,0"
                            Padding="12"
                            BorderBrush="#CFC7B8"
                            BorderThickness="1"
                            Background="#ECE7DC">
                        <StackPanel>
                            <TextBlock Text="Summary" FontWeight="SemiBold" />
                            <TextBlock Margin="0,8,0,0">
                                <Run Text="Total files: " />
                                <Run Text="{Binding TotalFiles, Mode=OneWay}" FontWeight="SemiBold" />
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Total lines: " />
                                <Run Text="{Binding TotalLines, Mode=OneWay}" FontWeight="SemiBold" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="#B8B1A3"
                    BorderThickness="1"
                    Background="#F8F5EE">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="14"
                            BorderBrush="#CFC7B8"
                            BorderThickness="0,0,0,1"
                            Background="#F0EBE1">
                        <StackPanel>
                            <TextBlock Text="Options"
                                       Margin="0,0,0,8"
                                       FontWeight="SemiBold"
                                       Foreground="#242B33" />
                            <WrapPanel>
                                <CheckBox Content="Include title page"
                                          IsChecked="{Binding IncludeTitlePage}" />
                                <CheckBox Content="Include file inventory"
                                          IsChecked="{Binding IncludeFileInventory}" />
                                <CheckBox Content="Include TODO/FIXME index"
                                          IsChecked="{Binding IncludeTodoIndex}" />
                                <CheckBox Content="Include source listing"
                                          IsChecked="{Binding IncludeSourceListing}" />
                                <CheckBox Content="Page break between files"
                                          IsChecked="{Binding PageBreakBetweenFiles}" />
                                <CheckBox Content="Syntax highlighting"
                                          IsChecked="{Binding UseSyntaxHighlighting}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <wv2:WebView2 x:Name="PreviewBrowser"
                                  Grid.Row="1"
                                  DefaultBackgroundColor="#FFFDF7" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#D8D1C4"
                Padding="12,7">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#242B33"
                       TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</Window>
